{
  "name": "juhani.mobi",
  "version": "0.0.1",
  "dependencies": {
    "classnames": "^2.2.5",
    "eslint-plugin-react": "^7.11.1",
    "fuse.js": "^3.3.0",
    "i18next": "^19.0.1",
    "prop-types": "^15.5.10",
    "raven-js": "^3.22.2",
    "react": "16.12.0",
    "react-addons-css-transition-group": "^15.6.0",
    "react-burger-menu": "^2.6.1",
    "react-dom": "16.12.0",
    "react-ga": "^2.4.1",
    "react-i18next": "^9.0.10",
    "react-redux": "7.1.3",
    "react-router": "^5.1.2",
    "react-router-dom": "^5.1.2",
    "react-router-prop-types": "^1.0.4",
    "react-sortable-hoc": "^0.6.7",
    "redux": "4.0.4",
    "redux-storage": "^4.1.2",
    "redux-storage-engine-localstorage": "^1.1.4",
    "redux-thunk": "^2.3.0",
    "uuid": "^3.3.3"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "deploy": "./deploy-to-s3.sh",
    "test": "NODE_PATH=src/ react-scripts test --env=jsdom --watchAll=false",
    "test-ci": "CI=true NODE_PATH=src/ react-scripts test --env=jsdom --coverage",
    "eslint": "eslint src/*.js src/**/*.js src/**/*.jsx",
    "eslint-fix": "eslint src/*.js src/**/*.js src/**/*.jsx --fix",
    "csslint": "stylelint src/*.css src/**/*.css",
    "csslint-fix": "stylelint src/*.css src/**/*.css --fix",
    "test:e2e": "bash -c 'source $NVM_DIR/nvm.sh && nvm exec 22 npx playwright test'",
    "test:e2e:ui": "bash -c 'source $NVM_DIR/nvm.sh && nvm exec 22 npx playwright test --ui'",
    "test:e2e:headed": "bash -c 'source $NVM_DIR/nvm.sh && nvm exec 22 npx playwright test --headed'"
  },
  "pre-commit": [
    "eslint",
    "csslint",
    "test-ci"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-react": "^5.1.3",
    "codecov": "^3.1.0",
    "enzyme": "^3.8.0",
    "enzyme-adapter-react-16": "^1.8.0",
    "jest-enzyme": "^7.0.1",
    "pre-commit": "^1.2.2",
    "react-scripts": "^2.1.3",
    "react-test-renderer": "^16.7.0",
    "stylelint": "^9.8.0",
    "stylelint-config-standard": "^18.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "wtf_wikipedia": "^7.2.8"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ]
}
