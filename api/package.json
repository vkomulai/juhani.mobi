    "scrape-it": "^5.2.0",
    "serverless-http": "^3",
    "serverless-plugin-warmup": "^8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/express": "^4.17.2",
    "@types/node": "^20",
    "@types/jest": "^29",
    "jest": "^29",
    "serverless-domain-manager": "^7",
    "serverless-dynamodb": "^0.2",
    "serverless": "^3",
    "serverless-offline": "^13",
    "serverless-esbuild": "^1.54",
    "esbuild": "^0.25",
    "ts-jest": "^29",
    "typescript": "^5.9"
